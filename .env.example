# Next.js & API routes — copy to `.env.local` for local dev.
# Vercel: Project → Settings → Environment Variables (same names).

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional: absolute site URL for redirects or emails
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# FastAPI (Python) — copy this file to `.env` in the repo root if you use uvicorn
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
